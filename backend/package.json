{
  "name": "medigo-backend",
  "version": "1.0.0",
  "description": "MEDIGO Microservices Workspace",
  "main": "index.js",
  "scripts": {
    "start:auth": "cd services/auth-service && npm run dev",
    "start:patient": "cd services/patient-service && npm run dev",
    "start:admin": "cd services/admin-service && npm run dev",
    "dev": "concurrently -n \"AUTH,PATIENT,ADMIN\" -c \"cyan,green,magenta\" \"npm run start:auth\" \"npm run start:patient\" \"npm run start:admin\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}